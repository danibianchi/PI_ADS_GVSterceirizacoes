      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ token }}" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"telefone\": \"(11) 98888-5678\"\n}"
      },
      "description": "Atualiza parcialmente um cliente. Substitua :id pelo ID do cliente."
