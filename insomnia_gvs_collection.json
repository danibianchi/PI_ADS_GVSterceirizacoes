      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ token }}" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"nome\": \"Empresa Exemplo LTDA\",\n  \"cnpj\": \"12.345.678/0001-99\",\n  \"email\": \"contato@empresa.com\",\n  \"telefone\": \"(11) 99999-1234\",\n  \"cidade\": \"Indaiatuba\",\n  \"estado\": \"SP\"\n}"
      },
      "description": "Cadastra um novo cliente. O Zod valida os campos antes de salvar no MongoDB."
    },
    {
      "_id": "req_clientes_put",
