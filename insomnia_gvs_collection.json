    {
      "_id": "req_register",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Registrar Usuário (POST)",
      "method": "POST",
      "url": "{{ base_url }}/auth/register",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"nome\": \"Admin GVS\",\n  \"email\": \"admin@gvs.com\",\n  \"senha\": \"admin123\"\n}"
      },
      "description": "Cria um novo usuário no sistema. Execute apenas uma vez para criar o admin. Resposta: { id, nome, email }"
    },
    {
      "_id": "req_login",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Login (POST) → Salvar token!",
      "method": "POST",
      "url": "{{ base_url }}/auth/login",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"admin@gvs.com\",\n  \"senha\": \"admin123\"\n}"
      },
      "description": "Faz login e retorna um token JWT. Copie o token da resposta, cole na variável de ambiente 'token' e use nas demais rotas protegidas."
    },
    {
      "_id": "fld_clientes",
      "_type": "request_group",
      "parentId": "wrk_gvs_001",
      "name": "👥 Clientes"
    },
    {
      "_id": "req_clientes_get",
      "_type": "request",
      "parentId": "fld_clientes",
      "name": "Listar Clientes (GET)",
      "method": "GET",
      "url": "{{ base_url }}/clientes",
      "headers": [{ "name": "Authorization", "value": "Bearer {{ token }}" }],
      "description": "Retorna todos os clientes cadastrados. Requer token JWT no header."
    },
    {
      "_id": "req_clientes_get_id",
      "_type": "request",
      "parentId": "fld_clientes",
      "name": "Buscar Cliente por ID (GET)",
      "method": "GET",
      "url": "{{ base_url }}/clientes/:id",
      "headers": [{ "name": "Authorization", "value": "Bearer {{ token }}" }],
      "description": "Substitua :id pelo _id do cliente que deseja buscar."
    },
    {
      "_id": "req_clientes_post",
      "_type": "request",
      "parentId": "fld_clientes",
      "name": "Criar Cliente (POST)",
