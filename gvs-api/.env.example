# =============================================
# ARQUIVO DE EXEMPLO — NÃO contém dados reais
# Copie este arquivo, renomeie para .env
# e preencha com suas próprias credenciais
# =============================================

# Porta onde o servidor vai rodar localmente
PORT=3000

# String de conexão do MongoDB
# Exemplo com MongoDB Atlas (nuvem):
# MONGODB_URI=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/?appName=<app>
# Exemplo com MongoDB local:
# MONGODB_URI=mongodb://localhost:27017/gvs
MONGODB_URI=

# Chave secreta para geração dos tokens JWT
# Use uma string longa e aleatória (mín. 32 caracteres)
JWT_SECRET=
